{
  "manifest_version": 3,
  "name": "RR – רובינשטיין רוזנטל שמאות מקרקעין",
  "version": "1.0",
  "description": "חיבור מערכת ניהול תיקים לאתר עסקאות נדלן של רשות המיסים",
  "icons": {
    "16": "Logo_smol.png",
    "32": "Logo_smol.png",
    "48": "Logo_smol.png",
    "128": "Logo_smol.png"
  },
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://nadlan.taxes.gov.il/*",
    "https://rr-real-estate.github.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://rr-real-estate.github.io/*"],
      "js": ["content_webapp.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://nadlan.taxes.gov.il/*"],
      "js": ["xlsx.full.min.js", "content_nadlan.js"],
      "run_at": "document_idle"
    }
  ]
}
